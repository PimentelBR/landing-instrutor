generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Instrutor {
  id              String   @id @default(cuid())
  slug            String   @unique
  nome            String
  iniciais        String
  avatarColor     String   @default("from-blue-500 to-blue-700")
  bairro          String
  cidade          String   @default("Vila Velha")
  preco           Int
  categorias      String[]
  especialidades  String[]
  experiencia     Int
  premium         Boolean  @default(false)
  verificado      Boolean  @default(false)
  disponivel      Boolean  @default(true)
  bio             String
  sobre           String
  telefone        String
  email           String?  @unique
  senha           String?
  alunosFormados  Int      @default(0)
  aulasRealizadas Int      @default(0)
  tempoResposta   String   @default("< 2 horas")
  taxaAprovacao   Int      @default(0)
  criadoEm        DateTime @default(now())
  atualizadoEm    DateTime @updatedAt

  horarios     HorarioInstrutor[]
  agendamentos Agendamento[]
  avaliacoes   Avaliacao[]
}

model HorarioInstrutor {
  id          String    @id @default(cuid())
  instrutorId String
  dia         String
  slots       String[]
  instrutor   Instrutor @relation(fields: [instrutorId], references: [id], onDelete: Cascade)

  @@index([instrutorId])
}

model Agendamento {
  id            String    @id @default(cuid())
  instrutorId   String
  nomeAluno     String
  telefoneAluno String
  emailAluno    String?
  dia           String
  horario       String
  status        String    @default("pendente")
  observacoes   String?
  criadoEm      DateTime  @default(now())
  atualizadoEm  DateTime  @updatedAt
  instrutor     Instrutor @relation(fields: [instrutorId], references: [id], onDelete: Cascade)

  @@index([instrutorId])
}

model Avaliacao {
  id          String    @id @default(cuid())
  instrutorId String
  nome        String
  iniciais    String
  nota        Int
  texto       String
  data        String
  criadoEm    DateTime  @default(now())
  instrutor   Instrutor @relation(fields: [instrutorId], references: [id], onDelete: Cascade)

  @@index([instrutorId])
}
